{
  "name": "video-control",
  "displayName": "视频调速 · Video Speed",
  "version": "1.0.0",
  "description": "鼠标悬浮在视频上时，使用 Shift + 滚轮调整播放速度，使用 Ctrl + 滚轮快进/快退（5 秒步长）；Shift + 点击视频恢复 1 倍速。",
  "author": "王宏亮 <401765060@qq.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "sass": "^1.99.0",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ]
  }
}
